       <property name="styleSheet">
        <string notr="true">#login_page {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, 
                stop:0 #6a11cb, stop:1 #2575fc);
}
#login_card_frame {
    background-color: rgba(255, 255, 255, 0.95); 
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.3);
}

QLineEdit {
    background-color: #f8f9fa;
    border: 2px solid #e9ecef;
    border-radius: 12px;
    padding: 12px;
    font-size: 14px;
    color: #495057;
    margin-bottom: 5px;
}

QLineEdit:focus {
    border: 2px solid #3498db;
    background-color: #ffffff;
}

QLabel#username_label_login, QLabel#password_label_login {
    color: #576574; 
    font-size: 11px;
    font-weight: bold;
    text-transform: uppercase;
    margin-bottom: 2px;
}

#welcome_label_login {
    color: #2c3e50; 
    font-family: &quot;Segoe UI Semibold&quot;, &quot;Trebuchet MS&quot;;
    font-size: 28px;
    font-weight: 700;
    letter-spacing: 0.5px;
    padding-bottom: 15px; 
    border-bottom: 2px solid #3498db; 
}

#subtitle_label_login {
    color: #95a5a6;
    font-size: 13px;
    margin-bottom: 20px;
}

QPushButton#login_btn_login {
    background-color: #3498db;
    color: white;
    font-weight: bold;
    font-size: 15px;
    border-radius: 12px;
    padding: 12px;
    min-width: 120px;
}

QPushButton#login_btn_login:hover {
    background-color: #2980b9;
}

QPushButton#login_btn_login:pressed {
    background-color: #1d6fa5; 
    padding-top: 12px; 
    padding-left: 14px;
}

QPushButton#signup_btn_login {
    background-color: transparent;
    color: #3498db;
    font-weight: bold;
    border: 2px solid #3498db;
    border-radius: 12px;
    padding: 10px;
    min-width: 120px;
}

QPushButton#signup_btn_login:hover {
    background-color: #f0f7ff;
} 

QPushButton#signup_btn_login:pressed {
    background-color: #d6eaf8; 
    border: 2px solid #2980b9;
}</string>

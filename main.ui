    font-weight: bold;
    margin-bottom: 20px;
}

QRadioButton {
    color: #4b5563;
    font-size: 14px;
    padding: 12px;
    background-color: #f9fafb;
    border: 2px solid #f3f4f6;
    border-radius: 10px;
    spacing: 10px;
}

QRadioButton:hover {
    background-color: #f0f7ff;
    border: 2px solid #3498db;
}

QRadioButton::indicator {
    width: 18px;
    height: 18px;
}

QRadioButton:checked {
    background-color: #ebf5fb;
    border: 2px solid #3498db;
    color: #2980b9;
    font-weight: bold;
}</string>
